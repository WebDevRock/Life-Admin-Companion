# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Database
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/life_admin

# Session
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_session_secret_min_32_chars

# Firebase Admin SDK
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content of the downloaded key file as a single line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Email reminders (optional — reminders are disabled if not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@yourdomain.com
